<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_library_book_tree" model="ir.ui.view">
        <field name="name">library.book.tree</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <list>
                <field name="title"/>
                <field name="author"/>
                <field name="isbn"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_library_book_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">library.book</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_set_borrowed" string="Mark as Borrowed" type="object" invisible="status == 'borrowed'"/>
                    <button name="action_set_available" string="Mark as Available" type="object" invisible="status == 'available'"/>
                    <button name="action_set_lost" string="Mark as Lost" type="object" invisible="status == 'lost'"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="title"/>
                            <field name="author"/>
                            <field name="genre"/>
                        </group>
                        <group>
                            <field name="publication_date"/>
                            <field name="isbn"/>
                            
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_library_book" model="ir.actions.act_window">
        <field name="name">Books</field>
        <field name="res_model">library.book</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
