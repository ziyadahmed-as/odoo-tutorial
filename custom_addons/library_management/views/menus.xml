<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Main Menu ────────────────────────────────────────── -->
    <menuitem id="menu_library_root"
              name="Library"
              web_icon="library_management,static/description/icon.png"
              sequence="10"/>

    <!-- ── Sub Menus ────────────────────────────────────────── -->
    <menuitem id="menu_library_books"
              name="Books"
              parent="menu_library_root"
              action="action_library_book"
              sequence="10"/>

    <menuitem id="menu_library_loans"
              name="Loans"
              parent="menu_library_root"
              action="action_library_loan"
              sequence="20"/>

    <menuitem id="menu_library_config"
              name="Configuration"
              parent="menu_library_root"
              groups="library_management.group_library_manager"
              sequence="100"/>

    <menuitem id="menu_library_settings_groups"
              name="Access Groups"
              parent="menu_library_config"
              action="base.action_res_groups"
              sequence="10"/>

</odoo>
