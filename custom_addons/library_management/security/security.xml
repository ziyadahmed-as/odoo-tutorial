<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Unique Category ID to avoid Odoo 19 clashes -->
        <record id="library_management_main_category" model="ir.module.category">
            <field name="name">Library Management</field>
            <field name="description">Security category for library management system.</field>
            <field name="sequence">50</field>
        </record>

        <!-- Library User -->
        <record id="group_library_user" model="res.groups">
            <field name="name">Library User</field>
            <field name="category_id" ref="library_management_main_category"/>
        </record>

        <!-- Library Manager -->
        <record id="group_library_manager" model="res.groups">
            <field name="name">Library Manager</field>
            <field name="category_id" ref="library_management_main_category"/>
            <field name="implied_ids" eval="[Command.link(ref('group_library_user'))]"/>
            <field name="user_ids" eval="[Command.link(ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
