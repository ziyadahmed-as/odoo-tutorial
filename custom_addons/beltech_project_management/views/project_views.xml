<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_beltech_project_tree" model="ir.ui.view">
        <name>beltech.project.tree</name>
        <model>beltech.project</model>
        <arch type="xml">
            <tree string="Projects" decoration-info="status == 'draft'" decoration-success="status == 'completed'" decoration-warning="status == 'in_progress'" decoration-danger="status == 'cancelled'">
                <field name="name"/>
                <field name="manager_id"/>
                <field name="department_id"/>
                <field name="budget" widget="monetary"/>
                <field name="deadline"/>
                <field name="progress" widget="progressbar"/>
                <field name="status" widget="badge" decoration-info="status == 'draft'" decoration-success="status == 'completed'" decoration-warning="status == 'in_progress'" decoration-danger="status == 'cancelled'"/>
            </tree>
        </arch>
    </record>

    <!-- Kanban View -->
    <record id="view_beltech_project_kanban" model="ir.ui.view">
        <name>beltech.project.kanban</name>
        <model>beltech.project</model>
        <arch type="xml">
            <kanban default_group_by="status">
                <field name="name"/>
                <field name="manager_id"/>
                <field name="budget"/>
                <field name="status"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div>
                                    Manager: <field name="manager_id"/>
                                </div>
                                <div>
                                    Budget: <field name="budget"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="status" widget="label_selection" options="{'classes': {'draft': 'default', 'in_progress': 'warning', 'completed': 'success', 'cancelled': 'danger'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </arch>
    </record>

    <!-- Pivot View -->
    <record id="view_beltech_project_pivot" model="ir.ui.view">
        <name>beltech.project.pivot</name>
        <model>beltech.project</model>
        <arch type="xml">
            <pivot string="Projects Analysis">
                <field name="manager_id" type="row"/>
                <field name="status" type="col"/>
                <field name="budget" type="measure"/>
            </pivot>
        </arch>
    </record>

    <!-- Graph View -->
    <record id="view_beltech_project_graph" model="ir.ui.view">
        <name>beltech.project.graph</name>
        <model>beltech.project</model>
        <arch type="xml">
            <graph string="Projects Analysis" type="bar">
                <field name="department_id"/>
                <field name="budget" type="measure"/>
            </graph>
        </arch>
    </record>

    <!-- Form View -->
    <record id="view_beltech_project_form" model="ir.ui.view">
        <name>beltech.project.form</name>
        <model>beltech.project</model>
        <arch type="xml">
            <form string="Project">
                <header>
                    <button name="action_in_progress" string="Start Project" type="object" class="oe_highlight" attrs="{'invisible': [('status', '!=', 'draft')]}"/>
                    <button name="action_done" string="Mark as Done" type="object" class="oe_highlight" attrs="{'invisible': [('status', '!=', 'in_progress')]}"/>
                    <button name="action_draft" string="Reset to Draft" type="object" attrs="{'invisible': [('status', 'not in', ['cancelled', 'completed'])]}"/>
                    <button name="action_cancel" string="Cancel" type="object" attrs="{'invisible': [('status', 'in', ['completed', 'cancelled'])]}"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_beltech_project)d" type="action" class="oe_stat_button" icon="fa-tasks">
                            <field name="task_count" string="Tasks" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Project Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="manager_id"/>
                            <field name="department_id"/>
                        </group>
                        <group>
                            <field name="budget"/>
                            <field name="deadline"/>
                            <field name="progress" widget="progressbar"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Tasks" name="tasks">
                            <field name="task_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="assigned_to"/>
                                    <field name="deadline"/>
                                    <field name="status"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Project details..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </arch>
    </record>

    <!-- Search View -->
    <record id="view_beltech_project_search" model="ir.ui.view">
        <name>beltech.project.search</name>
        <model>beltech.project</model>
        <arch type="xml">
            <search string="Search Projects">
                <field name="name"/>
                <field name="manager_id"/>
                <field name="department_id"/>
                <filter string="Draft" name="draft" domain="[('status', '=', 'draft')]"/>
                <filter string="In Progress" name="in_progress" domain="[('status', '=', 'in_progress')]"/>
                <filter string="Completed" name="completed" domain="[('status', '=', 'completed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Manager" name="manager" context="{'group_by': 'manager_id'}"/>
                    <filter string="Status" name="status" context="{'group_by': 'status'}"/>
                    <filter string="Department" name="department" context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </arch>
    </record>
</odoo>
