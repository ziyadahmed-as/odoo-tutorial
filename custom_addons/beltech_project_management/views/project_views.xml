<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Project List View -->
        <record id="view_beltech_project_tree" model="ir.ui.view">
            <field name="name">beltech.project.list</field>
            <field name="model">beltech.project</field>
            <field name="arch" type="xml">
                <list string="Projects" decoration-info="status == 'draft'" decoration-success="status == 'completed'" decoration-warning="status == 'in_progress'" decoration-danger="status == 'cancelled'">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="manager_id" widget="many2one_avatar_user"/>
                    <field name="budget" widget="monetary"/>
                    <field name="deadline" widget="remaining_days"/>
                    <field name="progress" widget="progressbar"/>
                    <field name="status" widget="badge" decoration-info="status == 'draft'" decoration-success="status == 'completed'" decoration-warning="status == 'in_progress'" decoration-danger="status == 'cancelled'"/>
                </list>
            </field>
        </record>

        <!-- Project Kanban View -->
        <record id="view_beltech_project_kanban" model="ir.ui.view">
            <field name="name">beltech.project.kanban</field>
            <field name="model">beltech.project</field>
            <field name="arch" type="xml">
                <kanban default_group_by="status" class="o_kanban_small_column" records_draggable="true">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="manager_id"/>
                    <field name="budget"/>
                    <field name="status"/>
                    <field name="color"/>
                    <field name="progress"/>
                    <templates>
                        <t t-name="card">
                            <div t-attf-class="#{!selection_mode ? 'oe_kanban_color_' + kanban_getcolor(record.color.raw_value) : ''} oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            [<field name="code"/>] <field name="name"/>
                                        </strong>
                                    </div>
                                    <field name="color" widget="kanban_color_picker"/>
                                </div>
                                <div class="o_kanban_record_body mt-2">
                                    <div class="text-muted">
                                        <i class="fa fa-money mr-1" title="Budget"/> <field name="budget" widget="monetary"/>
                                    </div>
                                    <div class="mt-2">
                                        <field name="progress" widget="progressbar" options="{'current_value': 'progress', 'max_value': '100'}"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom mt-3">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="status" widget="label_selection" options="{'classes': {'draft': 'info', 'in_progress': 'warning', 'completed': 'success', 'cancelled': 'danger'}}"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="manager_id" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Project Form View -->
        <record id="view_beltech_project_form" model="ir.ui.view">
            <field name="name">beltech.project.form</field>
            <field name="model">beltech.project</field>
            <field name="arch" type="xml">
                <form string="Project">
                    <header>
                        <button name="action_in_progress" string="Start Project" type="object" class="oe_highlight" invisible="status != 'draft'"/>
                        <button name="action_completed" string="Mark as Done" type="object" class="oe_highlight" invisible="status != 'in_progress'"/>
                        <button name="action_draft" string="Reset to Draft" type="object" invisible="status not in ['cancelled', 'completed']"/>
                        <button name="action_cancelled" string="Cancel" type="object" invisible="status in ['completed', 'cancelled']"/>
                        <field name="status" widget="statusbar" statusbar_visible="draft,in_progress,completed"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="%(action_beltech_project_task)d" type="action" class="oe_stat_button" icon="fa-tasks" context="{'search_default_project_id': active_id, 'default_project_id': active_id}">
                                <field name="task_count" widget="statinfo" string="Tasks"/>
                            </button>
                        </div>
                        <widget name="web_ribbon" title="Completed" bg_color="text-bg-success" invisible="status != 'completed'"/>
                        <widget name="web_ribbon" title="Cancelled" bg_color="text-bg-danger" invisible="status != 'cancelled'"/>
                        <div class="oe_title">
                            <label for="name" string="Project Name"/>
                            <h1>
                                <field name="name" placeholder="e.g. Infrastructure Upgrade..."/>
                            </h1>
                            <h3>
                                <field name="code" class="text-muted"/>
                            </h3>
                        </div>
                        <group>
                            <group>
                                <field name="manager_id" widget="many2one_avatar_user"/>
                                <field name="budget" widget="monetary"/>
                            </group>
                            <group>
                                <field name="deadline"/>
                                <field name="progress" widget="percentpie"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Tasks" name="tasks">
                                <field name="task_ids">
                                    <list editable="bottom" decoration-success="status == 'done'" decoration-info="status == 'in_progress'">
                                        <field name="name"/>
                                        <field name="assigned_to" widget="many2one_avatar_user"/>
                                        <field name="deadline"/>
                                        <field name="status" widget="badge" decoration-success="status == 'done'" decoration-info="status == 'in_progress'"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Description" name="description">
                                <field name="description" placeholder="Project details and scope..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Task List View -->
        <record id="view_beltech_task_tree" model="ir.ui.view">
            <field name="name">beltech.project.task.list</field>
            <field name="model">beltech.project.task</field>
            <field name="arch" type="xml">
                <list string="Tasks">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="assigned_to" widget="many2one_avatar_user"/>
                    <field name="deadline"/>
                    <field name="status" widget="badge"/>
                </list>
            </field>
        </record>

        <!-- Task Search View -->
        <record id="view_beltech_task_search" model="ir.ui.view">
            <field name="name">beltech.project.task.search</field>
            <field name="model">beltech.project.task</field>
            <field name="arch" type="xml">
                <search string="Search Tasks">
                    <field name="name"/>
                    <field name="project_id"/>
                    <filter string="My Tasks" name="my_tasks" domain="[('assigned_to', '=', uid)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Project" name="group_by_project" context="{'group_by': 'project_id'}"/>
                        <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                    </group>
                </search>
            </field>
        </record>
    </data>
</odoo>
