<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_beltech_project" model="ir.module.category">
        <name>BelTech Project Management</name>
        <description>Helps you manage your projects and tasks.</description>
        <sequence>10</sequence>
    </record>

    <record id="group_beltech_user" model="res.groups">
        <name>User</name>
        <category_id ref="module_category_beltech_project"/>
        <implied_ids eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_beltech_manager" model="res.groups">
        <name>Manager</name>
        <category_id ref="module_category_beltech_project"/>
        <implied_ids eval="[(4, ref('group_beltech_user'))]"/>
        <users eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>
</odoo>
