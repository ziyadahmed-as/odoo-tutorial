<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="instructors_list_template" name="Instructors List">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="py-5 bg-primary text-white">
                    <div class="container text-center">
                        <h1 class="display-4 font-weight-bold">Our Instructors</h1>
                        <p class="lead">Learn from the best industry experts.</p>
                    </div>
                </section>
                <section class="py-5">
                    <div class="container">
                        <div class="row">
                            <t t-foreach="instructors" t-as="instructor">
                                <div class="col-lg-3 col-md-6 mb-4 text-center">
                                    <div class="instructor-card p-4 rounded shadow-sm hover-elevate bg-white">
                                        <div class="mb-3">
                                            <img t-if="instructor.image" t-att-src="image_data_uri(instructor.image)" class="rounded-circle shadow-sm" style="width: 150px; height: 150px; object-fit: cover;"/>
                                            <div t-else="" class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center" style="width: 150px; height: 150px;">
                                                <i class="fa fa-user fa-5x text-muted"></i>
                                            </div>
                                        </div>
                                        <h4 class="font-weight-bold" t-field="instructor.name"/>
                                        <p class="text-muted small mb-3" t-esc="instructor.bio[:100] + '...' if instructor.bio else ''"/>
                                        <div class="social-links">
                                            <a t-if="instructor.social_twitter" t-att-href="instructor.social_twitter" class="text-primary mx-2"><i class="fa fa-twitter"></i></a>
                                            <a t-if="instructor.social_linkedin" t-att-href="instructor.social_linkedin" class="text-primary mx-2"><i class="fa fa-linkedin"></i></a>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
