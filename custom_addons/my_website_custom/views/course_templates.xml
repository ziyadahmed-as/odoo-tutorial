<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Courses List Template -->
    <template id="courses_list_template" name="Courses List">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="s_banner py-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-lg-6">
                                <h1 class="display-3 font-weight-bold mb-4">Master New Skills</h1>
                                <p class="lead mb-4">Join thousands of students and start your learning journey today with our expert-led courses.</p>
                            </div>
                            <div class="col-lg-6 text-center">
                                <img src="/my_website_custom/static/src/img/hero_edu.png" class="img-fluid rounded shadow-lg" alt="Education"/>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="py-5 bg-light">
                    <div class="container">
                        <div class="row mb-5">
                            <div class="col-lg-12 text-center">
                                <h2 class="h1">Our Courses</h2>
                                <p class="text-muted">Explore our wide range of educational programs.</p>
                            </div>
                        </div>
                        <div class="row">
                            <t t-foreach="courses" t-as="course">
                                <div class="col-md-4 mb-4">
                                    <div class="card h-100 border-0 shadow-sm hover-elevate">
                                        <div t-if="course.image" class="card-img-top overflow-hidden" style="height: 200px;">
                                            <img t-att-src="image_data_uri(course.image)" class="w-100 h-100 object-fit-cover" t-att-alt="course.name"/>
                                        </div>
                                        <div t-else="" class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 200px;">
                                            <i class="fa fa-graduation-cap fa-4x text-white-50"></i>
                                        </div>
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <span class="badge badge-primary" t-field="course.level"/>
                                                <span class="text-primary font-weight-bold" t-esc="course.price if course.price > 0 else 'Free'"/>
                                            </div>
                                            <h5 class="card-title font-weight-bold" t-field="course.name"/>
                                            <p class="card-text text-muted small" t-esc="course.description[:100] + '...' if course.description else ''"/>
                                        </div>
                                        <div class="card-footer bg-transparent border-0 pb-4">
                                            <a t-attf-href="/course/#{course.id}" class="btn btn-outline-primary btn-block rounded-pill">View Details</a>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <!-- Course Detail Template -->
    <template id="course_detail_template" name="Course Detail">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="py-5">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-8">
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb bg-transparent p-0">
                                        <li class="breadcrumb-item"><a href="/courses">Courses</a></li>
                                        <li class="breadcrumb-item active" aria-current="page" t-field="course.name"/>
                                    </ol>
                                </nav>
                                <div t-if="request.params.get('enrolled')" class="alert alert-success alert-dismissible fade show" role="alert">
                                    <strong>Congratulations!</strong> You have successfully enrolled in this course.
                                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                        <span aria-hidden="true">&times;</span>
                                    </button>
                                </div>
                                <h1 class="display-4 font-weight-bold mb-3" t-field="course.name"/>
                                <div class="d-flex align-items-center mb-4">
                                    <div t-if="course.instructor_id.image" class="mr-3">
                                        <img t-att-src="image_data_uri(course.instructor_id.image)" class="rounded-circle" style="width: 50px; height: 50px; object-fit: cover;"/>
                                    </div>
                                    <div>
                                        <p class="mb-0">Instructor: <a t-attf-href="/instructors" t-field="course.instructor_id.name"/></p>
                                    </div>
                                </div>
                                <div class="course-main-image mb-5">
                                    <img t-if="course.image" t-att-src="image_data_uri(course.image)" class="img-fluid rounded shadow w-100"/>
                                </div>
                                <div class="content mb-5">
                                    <h3>About this course</h3>
                                    <div t-field="course.description"/>
                                </div>
                                <div class="requirements mb-5" t-if="course.requirements">
                                    <h3>Requirements</h3>
                                    <p t-field="course.requirements"/>
                                </div>
                            </div>
                            <div class="col-lg-4">
                                <div class="card border-0 shadow-lg sticky-top" style="top: 100px;">
                                    <div class="card-body p-4">
                                        <h2 class="h1 mb-4" t-esc="course.price if course.price > 0 else 'Free'"/>
                                        
                                        <t t-if="not is_enrolled">
                                            <a t-attf-href="/course/enroll/#{course.id}" class="btn btn-primary btn-lg btn-block mb-3 rounded-pill">Enroll Now</a>
                                        </t>
                                        <t t-else="">
                                            <button class="btn btn-success btn-lg btn-block mb-3 rounded-pill" disabled="disabled">
                                                <i class="fa fa-check-circle mr-2"></i> Enrolled
                                            </button>
                                        </t>

                                        <ul class="list-unstyled">
                                            <li class="mb-2"><i class="fa fa-clock-o text-primary mr-2"></i> <span t-field="course.duration"/></li>
                                            <li class="mb-2"><i class="fa fa-signal text-primary mr-2"></i> <span t-field="course.level"/></li>
                                            <li class="mb-2"><i class="fa fa-certificate text-primary mr-2"></i> Certificate of Completion</li>
                                        </ul>
                                    </div>
                                </div>
                                <div class="mt-4" t-if="course.student_ids">
                                    <h4>Registered Students</h4>
                                    <div class="d-flex flex-wrap">
                                        <t t-foreach="course.student_ids" t-as="student">
                                            <div class="mr-2 mb-2 text-center" style="width: 60px;">
                                                <img t-if="student.image_128" t-att-src="image_data_uri(student.image_128)" class="rounded-circle mb-1" style="width: 40px; height: 40px; object-fit: cover;"/>
                                                <div t-else="" class="rounded-circle bg-secondary d-flex align-items-center justify-content-center mx-auto mb-1" style="width: 40px; height: 40px;">
                                                    <i class="fa fa-user text-white-50"></i>
                                                </div>
                                                <small class="d-block text-truncate" t-esc="student.name"/>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
