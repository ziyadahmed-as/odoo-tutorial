<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="view_beltech_project_form" model="ir.ui.view">
            <field name="name">beltech.project.form</field>
            <field name="model">beltech.project</field>
            <field name="arch" type="xml">
                <form string="Project">
                    <header>
                        <field name="status" widget="statusbar" statusbar_visible="draft,in_progress,completed" options="{'clickable': '1'}"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Project Title..."/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="manager_id"/>
                                <field name="budget"/>
                            </group>
                            <group>
                                <field name="start_date"/>
                                <field name="end_date"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Description">
                                <field name="description" placeholder="Project Description..."/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- List View -->
        <record id="view_beltech_project_list" model="ir.ui.view">
            <field name="name">beltech.project.list</field>
            <field name="model">beltech.project</field>
            <field name="arch" type="xml">
                <list string="Projects">
                    <field name="name"/>
                    <field name="manager_id"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="budget"/>
                    <field name="status" widget="badge" 
                           decoration-info="status == 'draft'" 
                           decoration-warning="status == 'in_progress'" 
                           decoration-success="status == 'completed'" 
                           decoration-danger="status == 'cancelled'"/>
                </list>
            </field>
        </record>

        <!-- Kanban View -->
        <record id="view_beltech_project_kanban" model="ir.ui.view">
            <field name="name">beltech.project.kanban</field>
            <field name="model">beltech.project</field>
            <field name="arch" type="xml">
                <kanban default_group_by="status" class="o_kanban_small_column">
                    <field name="name"/>
                    <field name="manager_id"/>
                    <field name="status"/>
                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_global_click">
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <div class="o_kanban_record_subtitle">
                                        <field name="manager_id"/>
                                    </div>
                                    <div class="o_kanban_record_bottom">
                                        <div class="oe_kanban_bottom_left">
                                            <field name="status" widget="label_selection" options="{'classes': {'draft': 'default', 'in_progress': 'warning', 'completed': 'success', 'cancelled': 'danger'}}"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_beltech_project_search" model="ir.ui.view">
            <field name="name">beltech.project.search</field>
            <field name="model">beltech.project</field>
            <field name="arch" type="xml">
                <search string="Search Projects">
                    <field name="name" string="Project Name"/>
                    <field name="manager_id"/>
                    <separator/>
                    <filter string="Draft" name="draft" domain="[('status', '=', 'draft')]"/>
                    <filter string="In Progress" name="in_progress" domain="[('status', '=', 'in_progress')]"/>
                    <filter string="Completed" name="completed" domain="[('status', '=', 'completed')]"/>
                    <group expand="0" string="Group By">
                        <filter string="Manager" name="group_by_manager" context="{'group_by': 'manager_id'}"/>
                        <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_beltech_project" model="ir.actions.act_window">
            <field name="name">Projects</field>
            <field name="res_model">beltech.project</field>
            <field name="view_mode">list,kanban,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first BelTech Project!
                </p>
            </field>
        </record>
    </data>
</odoo>
