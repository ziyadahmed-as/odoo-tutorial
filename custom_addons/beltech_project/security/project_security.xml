<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_beltech_project" model="ir.module.category">
            <field name="name">BelTech Projects</field>
            <field name="description">Helps you manage your projects.</field>
            <field name="sequence">10</field>
        </record>

        <record id="privilege_beltech_project" model="res.groups.privilege">
            <field name="name">Access Level</field>
            <field name="category_id" ref="module_category_beltech_project"/>
        </record>

        <record id="group_beltech_project_user" model="res.groups">
            <field name="name">Project User</field>
            <field name="privilege_id" ref="privilege_beltech_project"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">The user will be able to view projects.</field>
        </record>

        <record id="group_beltech_project_manager" model="res.groups">
            <field name="name">Project Manager</field>
            <field name="privilege_id" ref="privilege_beltech_project"/>
            <field name="implied_ids" eval="[(4, ref('group_beltech_project_user'))]"/>
            <field name="comment">The user will have full access to manage projects.</field>
        </record>
    </data>
</odoo>
